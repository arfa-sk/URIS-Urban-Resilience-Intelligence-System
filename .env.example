# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get yours at https://aistudio.google.com/apikey — never commit real keys.
GEMINI_API_KEY=""

# GEMINI_MODEL: Optional. Model name for analysis/simulate (default: gemini-1.5-flash).
# GEMINI_MODEL="gemini-1.5-flash"

# APP_URL: The URL where this applet is hosted (e.g. Cloud Run service URL).
APP_URL=""

# VITE_API_URL: Optional. When the frontend is deployed separately (e.g. Vercel), set this to your backend URL. No trailing slash.
# VITE_API_URL=""

# BRIGHT_DATA_API_KEY: Optional. For live jobs/property/news scraping via Bright Data.
BRIGHT_DATA_API_KEY=""
