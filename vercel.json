{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api?__path=/$1" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
